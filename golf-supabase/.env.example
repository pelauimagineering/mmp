# Copy to .env and fill in. The .env file is gitignored.
#
# Both values come from your Supabase project's API settings page:
#   Settings → API → Project URL
#   Settings → API → Service role key (NOT the anon key — service role
#   bypasses RLS and is used here for one-time seeding only)

SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE=eyJhbGciOiJIUzI1NiIs...

# The shared passphrase that gates score entry. Set this with:
#   insert into _secret (key, value) values ('golf_passphrase', 'YOUR-PHRASE')
#   on conflict (key) do update set value = excluded.value;
# Run that statement from the Supabase SQL editor — it never leaves the DB.
